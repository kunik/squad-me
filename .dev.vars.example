# Copy to .dev.vars (gitignored). Local secrets only — never commit real values.
# Cloud Dev / Production secrets use: wrangler secret put <NAME> --env <env>
# Full checklist + Turnstile widget create: docs/provision.md § "Identity / auth secrets"

SESSION_SIGNING_KEY=local-dev-only-change-me
NOTIFICATION_SINK_MODE=log

# OTP (phone verification) — see docs/plans/auth-registration-plan.md.
# `log` MUST stay set for local dev / tests: forces the fake provider, zero
# real Telegram Gateway / Twilio calls, and allows Turnstile Noop when
# TURNSTILE_SECRET_KEY is blank. Leave provider secrets blank locally.
# If you unset OTP_SINK_MODE while pointing at live Gateway, Turnstile secret
# is required or otp/start returns turnstile_misconfigured (fail closed).
OTP_SINK_MODE=log
TELEGRAM_GATEWAY_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Turnstile on POST /api/auth/phone/otp/start.
# Site key is public (also served by GET /api/auth/config); secret is server-only.
# Both blank + OTP_SINK_MODE=log = intentional local bypass.
# Create widget: npx wrangler turnstile widget create … (docs/provision.md).
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=
